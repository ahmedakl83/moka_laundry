rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // التحقق من أن المستخدم مسجل دخول
    function isSignedIn() {
      return request.auth != null;
    }

    // التحقق من دور المستخدم (مدير)
    function isAdmin() {
      return isSignedIn() && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin';
    }

    // التحقق من أن المستخدم هو صاحب البيانات أو مدير
    function isOwner(uid) {
      return isSignedIn() && (request.auth.uid == uid || isAdmin());
    }

    // قواعد المجموعات
    match /users/{userId} {
      allow read, write: if isOwner(userId);
    }

    match /orders/{orderId} {
      allow read: if isSignedIn();
      allow create: if isSignedIn(); // الموظف والمدير يمكنهم تسجيل الطلبات
      allow update, delete: if isAdmin(); // المدير فقط يعدل أو يحذف
    }

    match /customers/{customerId} {
      allow read: if isSignedIn();
      allow write: if isAdmin();
    }

    match /services/{serviceId} {
      allow read: if isSignedIn();
      allow write: if isAdmin();
    }

    match /expenses/{expenseId} {
      allow read, write: if isAdmin();
    }

    match /employees/{employeeId} {
      allow read, write: if isAdmin();
    }

    match /attendance/{recordId} {
      allow read, write: if isAdmin();
    }

    match /settings/invite {
      allow read: if true; // السماح بالقراءة للربط الأولي للجهاز
      allow write: if isAdmin();
    }
  }
}
